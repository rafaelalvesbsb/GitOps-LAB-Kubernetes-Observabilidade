#!/bin/bash
# Preparação de SO + instalação do kubeadm/kubelet/kubectl. Roda como root via
# "sudo -S bash common.sh" — idempotente (pode rodar de novo sem quebrar nada).
set -e

apt-get update -qq
apt-get install -y -qq curl gnupg apt-transport-https ca-certificates software-properties-common

swapoff -a || true
sed -i '/^[^#].*\sswap\s/s/^/# /' /etc/fstab

cat > /etc/modules-load.d/k8s.conf <<'EOF'
overlay
br_netfilter
EOF
modprobe overlay
modprobe br_netfilter

cat > /etc/sysctl.d/k8s.conf <<'EOF'
net.bridge.bridge-nf-call-iptables  = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward                 = 1
EOF
sysctl --system >/dev/null

apt-get install -y -qq containerd
mkdir -p /etc/containerd
[ -f /etc/containerd/config.toml ] || containerd config default > /etc/containerd/config.toml
sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /etc/containerd/config.toml
systemctl restart containerd
systemctl enable containerd >/dev/null 2>&1

mkdir -p /etc/apt/keyrings
if [ ! -f /etc/apt/keyrings/kubernetes-apt-keyring.gpg ]; then
  curl --retry 5 --retry-delay 3 --retry-all-errors -fsSL "https://pkgs.k8s.io/core:/stable:/v{{ kube_version }}/deb/Release.key" | gpg --yes --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg
fi
echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v{{ kube_version }}/deb/ /" > /etc/apt/sources.list.d/kubernetes.list
apt-get update -qq
apt-get install -y -qq kubelet kubeadm kubectl
apt-mark hold kubelet kubeadm kubectl >/dev/null
systemctl enable kubelet >/dev/null 2>&1

echo "COMMON_SETUP_OK"
